# Credenciais e configuração local — nunca versionar
.env
config.local.json

# Artefatos gerados em tempo de execução (recriados automaticamente)
logs/
chrome_profile/
.venv/

# Empacotamento em .exe (build_exe.bat / PyInstaller) — gerado a cada build,
# não deve ir para o histórico do Git (é grande e muda toda hora). Distribua
# pelo GitHub Releases em vez de commitar — veja docs/DISTRIBUICAO.md.
build/
dist/
*.spec

# Documentação gerada localmente (contém informações internas) —
# fica só na máquina de quem roda o build_pdf.py / build.js, não no repo
docs/*.docx
docs/*.pdf

# Python
__pycache__/
*.pyc

# Sistema operacional / editor
.DS_Store
Thumbs.db
